<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MonacoEditor.WinUI3.Sample.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MonacoEditor.WinUI3.Sample"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
	xmlns:monaco="using:MonacoEditor.WinUI3"
    Title="Monaco Editor - WinUI 3 Demo">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Spacing="8" 
                    Padding="12">
            <ComboBox x:Name="LanguageCombo" 
                      Header="Language" 
                      Width="160">
                <ComboBoxItem Content="plaintext" />
                <ComboBoxItem Content="javascript" />
                <ComboBoxItem Content="typescript" />
                <ComboBoxItem Content="csharp" />
                <ComboBoxItem Content="json" />
                <ComboBoxItem Content="xml" />
                <ComboBoxItem Content="html" />
                <ComboBoxItem Content="css" />
                <ComboBoxItem Content="python" />
                <ComboBoxItem Content="markdown" />
            </ComboBox>

            <ComboBox x:Name="ThemeCombo" 
                      Header="Theme" 
                      Width="140">
                <ComboBoxItem Content="vs" 
                              IsSelected="True" />
                <ComboBoxItem Content="vs-dark" />
                <ComboBoxItem Content="hc-black" />
                <ComboBoxItem Content="hc-light" />
            </ComboBox>

            <CheckBox x:Name="ReadOnlyCheck" 
                      Content="Read-Only"
                      VerticalAlignment="Bottom"
                      Margin="0,0,0,4" />
            <Button Content="Set Text from C#"
                    Click="OnSetTextClicked"
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,4" />
            <Button Content="Get Text to C#"
                    Click="OnGetTextClicked"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,4" />
        </StackPanel>

        <!-- Monaco Editor (two-way bound to EditorText) -->
        <monaco:MonacoEditorControl x:Name="Editor"
                                    MonacoBaseUrl="monaco"
                                    Grid.Row="1"
                                    Text="{x:Bind EditorText, Mode=TwoWay}"
                                    EditorLanguage="plaintext"
                                    EditorTheme="vs"
                                    EditorReady="OnEditorReady"
                                    TextChanged="OnEditorTextChanged"
                                    Margin="12,0,12,0"
                                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4" />

        <!-- Status bar -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="2" 
                   Padding="12,6"
                   FontSize="12" 
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

        <!-- Two-way binding proof: TextBox mirrors editor content -->
        <TextBox Grid.Row="3"
                 Header="Two-Way Bound TextBox (mirrors editor)"
                 Text="{x:Bind EditorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Margin="12,0,12,12"
                 IsSpellCheckEnabled="False" />
    </Grid>
</Window>
